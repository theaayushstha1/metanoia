# --- Hyperswitch (sandbox) ---
# Get these from https://app.hyperswitch.io
# Secret key (server only, NEVER expose to browser). Starts with snd_
HYPERSWITCH_SECRET_KEY=snd_xxx
# Publishable key (safe in browser). Starts with pk_snd_
NEXT_PUBLIC_HYPERSWITCH_PUBLISHABLE_KEY=pk_snd_xxx
# Sandbox API base
HYPERSWITCH_BASE_URL=https://sandbox.hyperswitch.io
# Optional: only needed once you have more than one business profile
HYPERSWITCH_PROFILE_ID=
# Optional payment-only sandbox route (for example Fauxpay). If omitted, the
# checkout uses the mandate connector below.
HYPERSWITCH_CHECKOUT_CONNECTOR=
HYPERSWITCH_CHECKOUT_CONNECTOR_MCA=
# Saved-card/recurring connector (for example Stripe).
HYPERSWITCH_MANDATE_CONNECTOR=stripe
HYPERSWITCH_MANDATE_CONNECTOR_MCA=
# For verifying webhooks (Business profile -> payment_response_hash_key)
HYPERSWITCH_PAYMENT_RESPONSE_HASH_KEY=

# --- Buyer-agent LLM: Gemini on Vertex AI ---
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=global
# Local dev: run `gcloud auth application-default login`
# Deploy: set GOOGLE_VERTEX_CREDENTIALS to a service-account JSON (stringified)
GOOGLE_VERTEX_CREDENTIALS=

# --- Durable state (optional; runs in-memory if unset): Cloud SQL Postgres ---
CLOUD_SQL_CONNECTION_NAME=
CLOUD_SQL_DATABASE=metanoia
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=

# --- App ---
# Public base URL of the deployed app (used for return_url + webhooks). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
